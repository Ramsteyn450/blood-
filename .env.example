# Server Configuration
PORT=5000
NODE_ENV=production
CLIENT_URL=http://localhost:5000

# Database Configuration
# Get your URI from MongoDB Atlas (https://www.mongodb.com/cloud/atlas) or run MongoDB locally
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lifeflow?retryWrites=true&w=majority

# Security Configuration
# Change this to a long random secret key in production
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Optional Frontend Configuration (Build-time)
VITE_API_URL=/api
VITE_APP_NAME=LifeFlow
